# Copy to .env.local (gitignored) and fill in real values.
# Used by Vite dev server proxy to inject the API key.
# Never commit .env.local — secrets stay out of the browser bundle.

EFPF_API_BASE=https://ecofactortech.com/wp-json/efpf/v1
EFPF_API_KEY=your-api-key-here

# Nova Poshta API key — used client-side for delivery selection.
# Get one at https://novaposhta.ua → Personal cabinet → Security → API keys.
# When empty, the app falls back to mock cities/branches so the UI still works.
VITE_NOVA_POSHTA_API_KEY=

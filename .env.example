# ECOFACTOR EFPF (existing product catalog)
EFPF_API_BASE=https://ecofactortech.com/wp-json/efpf/v1
EFPF_API_KEY=

# Lubeavto Partner API (auto rubric: electric + hybrid in stock)
# Token sits in the bidbiders project's .env.local under VITE_CALCULATOR_API_TOKEN —
# copy that same value here. The Vite proxy injects it as `Authorization: Bearer ...`.
LUBEAVTO_API_BASE=https://api-lubeavto-partner.azurewebsites.net
LUBEAVTO_API_TOKEN=

# PostHog analytics (project API key — public, safe to ship in client bundle)
# Sign up at https://posthog.com → Project Settings → Project API Key
# Leave empty to disable analytics in dev.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

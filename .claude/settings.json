{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Bash(rm -rf *)",
      "Bash(git reset --hard *)",
      "Bash(git push --force *)",
      "Bash(git clean -fd *)"
    ],
    "allow": [
      "Bash(pwd)",
      "Bash(ls *)",
      "Bash(git status)",
      "Bash(git branch)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(node -v)",
      "Bash(npm -v)",
      "Bash(npm install)",
      "Bash(npm run build)",
      "Bash(npm run lint)",
      "Bash(npm run typecheck)",
      "Bash(npm test *)",
      "Bash(npm run dev)",
      "Bash(bash scripts/ai/preflight.sh)"
    ]
  }
}
